.DS_Store
*.swp

# Compound Memory — transient runtime state (regenerated by the hooks)
.pending_session_write
.pending_session_writes/
.session_snapshots/
.claude/hooks/*.log

# Local secrets — NEVER commit
.env
keys/
*_ed25519
*_rsa
*.pem
id_*

# Local-only Claude Code settings (machine-specific paths/permissions)
.claude/settings.local.json

# Tool output / scratch
.playwright-mcp/
